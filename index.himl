<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ひよこ育成ゲーム</title>
<style>
body { text-align:center; font-family:sans-serif; background:#fffbe6; padding-top:50px;}
#chick { width:200px; height:200px; margin-top:20px; }
input, button { font-size:16px; padding:5px 10px; margin-top:10px; }
</style>
</head>
<body>

<h1>ひよこ育成ゲーム 🐣</h1>

<p>今日勉強した時間を入力してください（時間）:</p>
<input type="number" id="studyTime" min="0" max="24" step="0.1">
<br>
<button onclick="growChick()">育てる</button>

<img id="chick" src="https://upload.wikimedia.org/wikipedia/commons/3/3e/Chick_2.JPG" alt="ひよこ">

<p id="message"></p>

<script>
function growChick(){
  let time = parseFloat(document.getElementById('studyTime').value);
  const chick = document.getElementById('chick');
  const msg = document.getElementById('message');

  if(isNaN(time) || time < 0){
    msg.textContent = "正しい時間を入力してください";
    return;
  }

  // 成長段階
  if(time < 2){
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/3/3e/Chick_2.JPG"; // 小さいひよこ
    msg.textContent = "小さいひよこです";
  } else if(time < 5){
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/f/f7/Chick_1.JPG"; // 少し大きい
    msg.textContent = "ひよこが少し成長しました！";
  } else if(time < 10){
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/3/32/Chick_3.JPG"; // 中くらい
    msg.textContent = "ひよこが元気に成長しています！";
  } else if(time < 12){
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/7/7f/Chicken_in_Rest.JPG"; // 成鶏
    msg.textContent = "ついに鶏になりました！";
  } else {
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/1/1a/Chicken_flying.jpg"; // 飛べる鶏
    msg.textContent = "なんと！鶏が飛べるようになりました！🕊️";
  }

  // 1日リセット（テスト用に10秒後）
  setTimeout(() => {
    chick.src = "https://upload.wikimedia.org/wikipedia/commons/3/3e/Chick_2.JPG";
    msg.textContent = "新しい日が始まりました。ひよこはリセットされました";
    document.getElementById('studyTime').value = "";
  }, 10000); // 10秒後にリセット
}
</script>

</body>
</html>
